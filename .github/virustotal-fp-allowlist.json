{
  "rules": [
    {
      "id": "windows-wacatac-microsoft",
      "engine": "Microsoft",
      "file_regex": "^basefwx-windows-(amd64|x86)\\.(exe|zip)$",
      "result_regex": "^Trojan:Win32/Wacatac\\.B!ml$",
      "reason": "Known ML false positive for unsigned release binaries."
    },
    {
      "id": "windows-malicious-secureage",
      "engine": "SecureAge",
      "file_regex": "^basefwx-windows-(amd64|x86)\\.(exe|zip)$",
      "result_regex": "^Malicious$",
      "reason": "Generic verdict with no family attribution."
    },
    {
      "id": "windows-aidetect-bkav-pro",
      "engine": "Bkav Pro",
      "file_regex": "^basefwx-windows-(amd64|x86)\\.(exe|zip)$",
      "result_regex": "^W64\\.AIDetectMalware$",
      "reason": "Heuristic AI detection repeatedly reported for unsigned CLI binaries."
    },
    {
      "id": "windows-malicious-confidence-crowdstrike",
      "engine": "CrowdStrike Falcon",
      "file_regex": "^basefwx-windows-(amd64|x86)\\.(exe|zip)$",
      "result_regex": "^Win/malicious_confidence_60% \\(D\\)$",
      "reason": "Confidence-only heuristic verdict without family attribution."
    },
    {
      "id": "windows-malicious-elastic",
      "engine": "Elastic",
      "file_regex": "^basefwx-windows-(amd64|x86)\\.(exe|zip)$",
      "result_regex": "^Malicious \\(moderate Confidence\\)$",
      "reason": "Moderate-confidence heuristic detection observed on release builds."
    },
    {
      "id": "windows-susgen-maxsecure",
      "engine": "MaxSecure",
      "file_regex": "^basefwx-windows-(amd64|x86)\\.(exe|zip)$",
      "result_regex": "^Trojan\\.Malware\\.300983\\.susgen$",
      "reason": "Heuristic signature reported as false positive."
    },
    {
      "id": "windows-wacatac-vba32",
      "engine": "VBA32",
      "file_regex": "^basefwx-windows-(amd64|x86)\\.(exe|zip)$",
      "result_regex": "^BScope\\.Trojan\\.Wacatac$",
      "reason": "Heuristic signature reported as false positive."
    }
  ]
}
